# Document Generation API Config (Optional)
# If this file exists, resume/cover letter generation will use these keys instead of .env
# Supports multiple keys separated by commas for rotation

# API Keys (Gemini, OpenAI, etc.)
LLM_API_KEYS=key1,key2,key3

# Number of documents before rotating keys
LLM_ROTATION_LIMIT=3

# Optional: Force a specific model (e.g., gemini-1.5-pro)
LLM_MODEL_OVERRIDE=
