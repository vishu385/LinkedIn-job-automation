# Scraping
APIFY_API_TOKEN=

# AI Scoring (Use any or all)
# You can provide multiple Gemini keys separated by commas for automatic rotation
GEMINI_API_KEY=key1,key2,key3,key4
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional: Force a specific provider (choices: gemini, openai, anthropic)
# AI_PROVIDER=gemini

# Optional: Number of jobs before rotating to the next API key (default: 8)
# ROTATION_LIMIT=8

# Telegram Alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Dream Job Config (Score >= this value triggers alert)
DREAM_JOB_SCORE=45

# Google Docs Config (Optional: Folder ID where resumes/cover letters will be saved)
# Leave empty to save to root of service account's Google Drive
# To get Folder ID: Open folder in Google Drive, copy ID from URL
GOOGLE_DOCS_FOLDER_ID=