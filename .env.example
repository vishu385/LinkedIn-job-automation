# Apify Config
APIFY_API_TOKEN=your_apify_api_token_here
APIFY_ACTOR_ID=curious_coder~linkedin-jobs-scraper
APIFY_SEARCH_URL=https://www.linkedin.com/jobs/search?keywords=Marketing+Manager&location=India
APIFY_MAX_JOBS=100

# AI Scoring (Use any or all)
# You can provide multiple Gemini keys separated by commas for automatic rotation
GEMINI_API_KEY=key1,key2,key3,key4
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional: Force a specific provider (choices: gemini, openai, anthropic)
# AI_PROVIDER=gemini

# Optional: Number of jobs before rotating to the next API key (default: 8)
LLM_ROTATION_LIMIT=8

# Telegram Alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Dream Job Config (Score >= this value triggers alert)
DREAM_JOB_SCORE=80

# Google Docs & Sheets OAuth Config (Modern Version)
# 1. Go to Google Cloud Console > Create "Desktop App" Client ID
# 2. Paste the ID and Secret below
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret_here

# Optional: Google Docs Folder ID (where resumes/cover letters will be saved)
# Leave empty to save to the root of your Google Drive
GOOGLE_DOCS_FOLDER_ID=

# Background Monitor Config
MONITOR_CHECK_INTERVAL=60sec